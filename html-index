    <style>
        :root {
            --primary: #007ac3;
            --secondary: #18addc;
            --accent: #25d366;
            --dark: #3b3b3b;
            --light: #f7f7f7;
            --white: #ffffff;
            --shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        * { box-sizing: border-box; }
        body { 
            font-family: 'Lato', sans-serif; 
            margin: 0; 
            padding: 0; 
            background-color: var(--light); 
            color: var(--dark); 
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 { font-family: 'Josefin Sans', sans-serif; }

        /* HEADER */
        header { 
            background: var(--white); 
            padding: 15px 5%; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            position: sticky; 
            top: 0; 
            z-index: 1000; 
            box-shadow: var(--shadow);
        }
        .logo img { max-width: 180px; height: auto; }
        nav a { 
            text-decoration: none; 
            color: var(--dark); 
            margin-left: 20px; 
            font-weight: 600; 
            font-size: 14px;
            text-transform: uppercase;
        }
        nav a:hover { color: var(--primary); }

        /* HERO SECTION */
        .hero { 
            background: linear-gradient(rgba(0, 122, 195, 0.6), rgba(0, 122, 195, 0.6)), url('https://guanaclean.com/wp-content/uploads/2024/10/limpieza-de-colchones.jpg');
            background-size: cover; 
            background-position: center; 
            height: 500px; 
            display: flex; 
            flex-direction: column;
            align-items: center; 
            justify-content: center; 
            text-align: center; 
            color: var(--white);
            padding: 0 20px;
        }
        .hero h1 { font-size: clamp(2rem, 5vw, 4rem); margin-bottom: 10px; text-shadow: 2px 2px 10px rgba(0,0,0,0.3); }
        .hero p { font-size: 1.2rem; max-width: 700px; margin-bottom: 30px; }

        /* SECCIONES COMUNES */
        .container { max-width: 1200px; margin: auto; padding: 80px 20px; }
        .section-title { 
            color: var(--primary); 
            text-align: center; 
            font-size: 2.5rem; 
            margin-bottom: 40px; 
            position: relative;
        }
        .section-title::after {
            content: ''; width: 60px; height: 3px; background: var(--secondary);
            position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);
        }

        /* GRID DE SERVICIOS */
        .services-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
            gap: 30px; 
        }
        .card { 
            background: var(--white); 
            padding: 40px 30px; 
            border-radius: 15px; 
            text-align: center; 
            box-shadow: var(--shadow); 
            transition: transform 0.3s ease;
        }
        .card:hover { transform: translateY(-10px); }
        .card img { width: 70px; margin-bottom: 20px; }
        .card h3 { color: var(--primary); margin-bottom: 15px; text-transform: uppercase; }

        /* BOTONES */
        .btn { 
            background: var(--primary); 
            color: var(--white); 
            padding: 12px 30px; 
            text-decoration: none; 
            border-radius: 50px; 
            font-weight: bold; 
            display: inline-block; 
            transition: 0.3s; 
            border: none;
            cursor: pointer;
        }
        .btn:hover { background: var(--secondary); box-shadow: 0 5px 15px rgba(24, 173, 220, 0.4); }

        /* TESTIMONIOS */
        .testimonials { background: var(--white); }
        .stars { color: #ffc107; font-size: 22px; margin-bottom: 15px; }
        .testimonial-text { font-style: italic; color: #666; margin-bottom: 20px; }
        .client-name { font-weight: 700; color: var(--primary); margin: 0; }

        /* FORMULARIO */
        .contact-section { background: #eee; }
        .contact-flex { display: flex; flex-wrap: wrap; gap: 40px; }
        .contact-info { flex: 1; min-width: 300px; }
        .contact-form { 
            flex: 1; 
            min-width: 300px; 
            background: var(--white); 
            padding: 40px; 
            border-radius: 15px; 
            box-shadow: var(--shadow);
        }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: 600; }
        .form-group input, .form-group textarea { 
            width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: inherit;
        }
        .form-group textarea { height: 120px; }

        /* WHATSAPP FLOTANTE */
        .whatsapp-float {
            position: fixed; width: 60px; height: 60px; bottom: 30px; right: 30px; background-color: var(--accent);
            border-radius: 50px; text-align: center; box-shadow: 2px 5px 15px rgba(0,0,0,0.3); z-index: 10000;
            display: flex; align-items: center; justify-content: center; transition: 0.3s;
        }
        .whatsapp-float:hover { transform: scale(1.1) rotate(5deg); }
        .whatsapp-icon { width: 35px; height: 35px; }

        /* MODAL DE MENSAJE */
        #message-box {
            display: none; position: fixed; top: 20px; right: 20px; background: var(--primary); color: white;
            padding: 20px 40px; border-radius: 8px; z-index: 20000; box-shadow: var(--shadow);
        }

        @media (max-width: 768px) {
            header { flex-direction: column; gap: 15px; }
            nav a { margin: 0 10px; font-size: 12px; }
            .hero h1 { font-size: 2.2rem; }
        }
    </style>
</head>
